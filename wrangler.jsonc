{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "control-escape",
  "compatibility_date": "2026-03-29",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "www.control-escape.com",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
