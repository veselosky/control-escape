#!/usr/bin/env bash

# Based on the Taskfile format from https://github.com/adriancooney/Taskfile
# Please keep functions sorted alphabetically for ease of editing.

# A useful path mod
PATH=./node_modules/.bin:$PATH

#######################################################################
# Set some commonly used globals
#######################################################################
BASE_DIR=$(cd `dirname $0`; pwd)
# As a security precaution, ensure the BASE_DIR is not empty, and that
# the path it refers to is writable by the current user.
if [ -z "$BASE_DIR" ] || [ ! -w "$BASE_DIR" ]; then
    echo "Error: BASE_DIR is not set or not writable: '$BASE_DIR'"
    exit 1
fi
# Any script output should go to DATA_DIR
DATA_DIR="$BASE_DIR/var"
# Target 3.13, fallback to 3.x, then python
BASE_PYTHON=`which python3.13 || which python3 || which python`
PROJECT_NAME=`basename "$BASE_DIR"`

# Some ANSI colors for pretty messages
NORMAL="$(tput sgr0)"
BLACK="$(tput setaf 0)"
RED="$(tput setaf 1)"
GREEN="$(tput setaf 2)"
YELLOW="$(tput setaf 3)"
BLUE="$(tput setaf 4)"
MAGENTA="$(tput setaf 5)"
CYAN="$(tput setaf 6)"
WHITE="$(tput setaf 7)"

# Setup: ensure DATA_DIR exists and contains a .gitignore excluding all files.
mkdir -p "$DATA_DIR"
if [ ! -f "$DATA_DIR/.gitignore" ]; then
    echo "*" > "$DATA_DIR/.gitignore"
fi

#######################################################################
# Function declarations
#######################################################################

#######################################################################
function audit { ## Run code quality checks
    # Run a Hugo build with various warnings enabled, capturing output.
    # If the build fails, print an error and return failure.
    # See https://gohugo.io/troubleshooting/audit/
    BUILD_OUT="$DATA_DIR/hugo_build.out"
    BUILD_ERR="$DATA_DIR/hugo_build.err"
    AUDIT_ISSUES="$DATA_DIR/hugo_build_issues.txt"

    HUGO_MINIFY_TDEWOLFF_HTML_KEEPCOMMENTS=true \
    HUGO_ENABLEMISSINGTRANSLATIONPLACEHOLDERS=true \
    hugo > "$BUILD_OUT" 2> "$BUILD_ERR" \
    --cleanDestinationDir \
    --printI18nWarnings \
    --printPathWarnings \
    --printUnusedTemplates \
    --printMemoryUsage \
    --templateMetrics \
    --templateMetricsHints || { printf "%b %s\n" "${RED}✖${NORMAL}" "Hugo build failed!"; return 1; }

    # Search the generated public/ for known Hugo build warnings/markers.
    # Capture output (if any), print it, and save to a file when issues exist.
    issues=$(grep -inorE "<!-- raw HTML omitted -->|ZgotmplZ|\[i18n\]|\(<nil>\)|(&lt;nil&gt;)|hahahugo" "$BASE_DIR/public/" || true)

    if [ -z "${issues}" ]; then
        # No grep output -> success
        printf "%b %s\n" "${GREEN}✔${NORMAL}" "No issues detected"
        [ -f "$AUDIT_ISSUES" ] && rm -f "$AUDIT_ISSUES"
        return 0
    else
        # Print the issues to stdout and save to a file for later inspection
        echo "${issues}"
        echo "${issues}" > "$AUDIT_ISSUES"
        printf "%b %s\n" "${RED}✖${NORMAL}" "Build issues detected!"
        return 1
    fi
}

#######################################################################
function build { ## Build the static site (to public/)
    # Note: Django also uses /var/www/ for static files and media.
    # Building separately seems safer for now.
    hugo build --minify --cleanDestinationDir --gc --environment production
    npx pagefind --site "$BASE_DIR/public/"
}

#######################################################################
function deploy { ## Deploy the site to production (Cloudflare)
    build && npx wrangler deploy
}
#######################################################################
function help { ## Display usage for this application
    echo "$0 <task> <args>"
    echo "Tasks:"
    # compgen -A function | cat -n
    grep -E '^function [a-zA-Z_-]+ {.*?## .*$$' $0 | \
        sed -e 's/function //' | \
        sort | \
        awk 'BEGIN {FS = "{.*?## "}; {printf "\033[93m%-30s\033[92m %s\033[0m\n", $1, $2}'
    echo "VARIABLES:"
    echo "  BASE_DIR      : $BASE_DIR"
    echo "  BASE_PYTHON   : $BASE_PYTHON"
    echo "  PROJECT_NAME  : $PROJECT_NAME"
    echo ""
    echo "For production deployment, pull the desired branch from git, run 'build' then 'deploy'."
}

#######################################################################
function lighthouse { ## Audit the site for accessibility, SEO, performance, and best practices
    # Ensure a Hugo dev server is running on localhost:1313, run Lighthouse, then stop the server if we started it.
    REPORT="$BASE_DIR/var/lighthouse-report.html"
    HUGO_URL="http://127.0.0.1:1313"
    SERVER_STARTED_BY_SCRIPT=0

    # Start Hugo server if nothing is listening on :1313
    if command -v curl >/dev/null 2>&1; then
        if curl -sSf "$HUGO_URL" >/dev/null 2>&1; then
            echo "Using existing Hugo server at $HUGO_URL"
        else
            echo "Starting Hugo server..."
            hugo server -DF --bind 127.0.0.1 --port 1313 --disableLiveReload >/dev/null 2>&1 &
            HUGO_PID=$!
            SERVER_STARTED_BY_SCRIPT=1
            trap 'kill "$HUGO_PID" 2>/dev/null || true; wait "$HUGO_PID" 2>/dev/null || true' EXIT

            # Wait up to 30s for the server to become responsive
            timeout=30
            waited=0
            until curl -sSf "$HUGO_URL" >/dev/null 2>&1; do
                sleep 1
                waited=$((waited+1))
                if [ $waited -ge $timeout ]; then
                    echo "Error: Hugo server did not start within ${timeout}s"
                    kill "$HUGO_PID" 2>/dev/null || true
                    wait "$HUGO_PID" 2>/dev/null || true
                    return 1
                fi
            done
        fi
    else
        # No curl available: attempt to start server and wait briefly
        echo "Warning: 'curl' not found; starting Hugo server and waiting 3s..."
        hugo server -DF --bind 127.0.0.1 --port 1313 --disableLiveReload >/dev/null 2>&1 &
        HUGO_PID=$!
        SERVER_STARTED_BY_SCRIPT=1
        trap 'kill "$HUGO_PID" 2>/dev/null || true; wait "$HUGO_PID" 2>/dev/null || true' EXIT
        sleep 3
    fi

    # Select lighthouse command
    if command -v npx >/dev/null 2>&1; then
        CMD=(npx lighthouse "$HUGO_URL" --output html --output-path "$REPORT" --chrome-flags="--headless --no-sandbox")
    else
        echo "Error: npx is not installed."
        if [ "$SERVER_STARTED_BY_SCRIPT" -eq 1 ]; then
            kill "$HUGO_PID" 2>/dev/null || true
            wait "$HUGO_PID" 2>/dev/null || true
        fi
        exit 1
    fi

    # Run Lighthouse
    rc=0
    "${CMD[@]}" || rc=$?
    echo "Lighthouse report generated at $REPORT"

    # If we started the server, stop it now and clear the EXIT trap
    if [ "$SERVER_STARTED_BY_SCRIPT" -eq 1 ]; then
        echo "Stopping Hugo server (pid $HUGO_PID)..."
        kill "$HUGO_PID" 2>/dev/null || true
        wait "$HUGO_PID" 2>/dev/null || true
        trap - EXIT
    fi

    return $rc
}

#######################################################################
function serve { ## Run the Hugo development server with drafts and future content
    build
    hugo server -DF
}
function server { ## Alias for serve
    serve
}

#######################################################################
# Finally, execute it.
#######################################################################

TIMEFORMAT="Task completed in %3lR"
# Replace "help" with the name of the desired default function
time ${@:-help}
